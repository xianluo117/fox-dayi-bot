DISCORD_BOT_TOKEN=
OPENAI_API_KEY=""
OPENAI_API_BASE_URL=""
OPENAI_MODEL=""
IMAGE_REVIEW_MODEL=""
# 图片描述模型
IMAGE_DESCRIBE_MODEL=""
SYSTEM_PROMPT=""
DELETE_TEMP_FILES=""
MAX_PARALLEL=5
# 自动回复功能 - 监听的频道ID列表（用逗号分隔）
AUTO_REPLY_CHANNELS=
# 自动清理功能 - 临时文件
AUTO_GC=""
AUTO_GC_INTERVAL=""
AUTO_GC_GRACE=""
# 自动清理功能 - 存档文件
AUTO_ARCHIVE_GC=""
AUTO_ARCHIVE_GC_INTERVAL=""
AUTO_ARCHIVE_GC_GRACE=""
AUTO_ARCHIVE_GC_FOLDER=""

# 反馈功能配置
# 反馈信息转发的频道ID
COMMIT_CHANNEL_ID=

# (可选) RAG系统配置
# 向量化模型配置 - 使用与OpenAI兼容的API格式
# 向量化模型名称，例如 "text-embedding-3-small" 或 "text-embedding-ada-002"
EMBEDDING_MODEL=""
# 向量化API密钥 - 如果与OPENAI_API_KEY相同可以留空
EMBEDDING_API_KEY=
# 向量化API地址 - 如果与OPENAI_API_BASE_URL相同可以留空
EMBEDDING_API_BASE=
# RAG检索配置
# 检索的相关文档数量（1-10），默认为5
RAG_TOP_K=""
# 最小相似度阈值（0.0-1.0），低于此值的文档将被过滤，默认为0.7
RAG_MIN_SIMILARITY=""
# 是否启用RAG系统，设置为 "true" 启用，"false" 禁用，默认禁用
RAG_ENABLED=""

# RAG文档分块配置
# 每个文档块的大小（以tokens计），默认为500
RAG_CHUNK_SIZE=""
# 文档块之间的重叠大小（以tokens计），默认为50
RAG_CHUNK_OVERLAP=""

# (可选) 多模态RAG配置
# 是否启用多模态功能（需要支持多模态的embedding模型），默认为true
MULTIMODAL_RAG_ENABLED=""
# 图片最大尺寸，格式为 "宽度x高度"，默认为 "1024x1024"
IMAGE_MAX_SIZE=""
# 图片存储路径，默认为 "./rag_data/images"
IMAGE_STORAGE_PATH=""
# 多模态搜索模式：text_only, image_only, hybrid，默认为 "hybrid"
MULTIMODAL_SEARCH_MODE=""


# 前端随机模型功能
# 前端随机模型名称列表（用逗号分隔）
RANDOM_MODEL_NAMES=""

# 快速处罚功能配置
QUICK_PUNISH_ENABLED=true
# 可执行此命令的身份组ID列表（用逗号分隔）
QUICK_PUNISH_ROLES=
# QUICK_PUNISH_ROLES=1397937296040267849 #徽章大师
# 需要移除的身份组ID列表（用逗号分隔）- 需要替换为实际的身份组ID
QUICK_PUNISH_REMOVE_ROLES=
# 日志频道ID
QUICK_PUNISH_LOG_CHANNEL=
# 日志子区ID（可选，如果设置则优先使用子区）
QUICK_PUNISH_LOG_THREAD=
# 对接频道ID
QUICK_PUNISH_INTERFACE_CHANNEL=
# 申诉频道ID（在私信中提及）
QUICK_PUNISH_APPEAL_CHANNEL=
#对接机器人的用户ID
QUICK_PUNISH_INTERFACE_BOT_ID=

# alert 系统
TARGET_CHANNEL_OR_THREAD=
ALERT_CHANNEL_OR_THREAD=
MIN_INTERVAL=

# siliconflow 向量化API
SILICONFLOW_EMBEDDING_MODEL=""
SILICONFLOW_API_KEY=""