# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Project Specific Data (运行时生成的动态文件) ---
# 忽略所有临时文件目录
temp/

# 忽略 Tagger 的数据库存放位置
tagger/*
!tagger/put_tagger_db_here.txt

# 忽略广播和统计相关的动态 JSON
broadcast/broadcast_stats.json
broadcast/broadcast_threads.json

# 忽略 Mention 模块的运行时状态和日志
mention/*
!mention/.gitkeep
!mention/settings_example.json
!mention/threads_example.json
!mention/usage_stats.json
!mention/kb/.gitkeep

# 忽略 API Table 的历史记录
api_table/history.txt

